# Production Mode
FLASK_ENV=production
DEBUG=False
PROFILE=False

# Database
DATABASE_URL=sqlite:///studyhub.db?timeout=30&check_same_thread=False

# Secret Keys
SECRET_KEY=your-super-secret-key-change-this-to-random-string
EMAIL_SECRET_KEY=your-email-secret-key-change-this

# Session
SESSION_SECURE=False
SESSION_HTTPONLY=True

# Mail (Ethereal للاختبار)
MAIL_SERVER=smtp.ethereal.email
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-ethereal-username
MAIL_PASSWORD=your-ethereal-password
MAIL_DEFAULT_SENDER=noreply@studyhub.com

# Performance
SQLALCHEMY_POOL_SIZE=20
SQLALCHEMY_MAX_OVERFLOW=10
CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=300
TELEGRAM_BOT_TOKEN=8420509109:AAEcOvRUZVZzPw0abhUNjdetwMH7xjZI0SM